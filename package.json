{
  "name": "branch-deploy",
  "private": true,
  "description": "Enabling Branch Deployments through IssueOps with GitHub Actions",
  "type": "module",
  "scripts": {
    "format": "prettier --write '**/*.{js,ts}'",
    "format-check": "prettier --check '**/*.{js,ts}'",
    "typecheck": "tsc --noEmit",
    "typecheck:runtime": "tsc --project tsconfig.runtime.json",
    "lint": "eslint .",
    "package": "ncc build src/main.ts -o dist --source-map --license licenses.txt --target es2022",
    "test": "BRANCH_DEPLOY_VITEST_TEST=true vitest run --coverage",
    "ci-test": "npm run test",
    "check": "npm run format-check && npm run typecheck && npm run typecheck:runtime && npm run lint && npm run test",
    "all": "npm run check && npm run package",
    "bundle": "npm run package",
    "act": "npm run package && act issue_comment -e events/issue_comment_deploy.json -s GITHUB_TOKEN=faketoken -j test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/github/branch-deploy.git"
  },
  "keywords": [
    "actions",
    "issueops",
    "deployment",
    "github"
  ],
  "author": "Grant Birkinbine",
  "license": "MIT",
  "dependencies": {
    "@actions/github": "9.0.0",
    "@octokit/plugin-retry": "8.0.3",
    "nunjucks": "3.2.4",
    "yargs-parser": "22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.3.0",
    "@vercel/ncc": "0.44.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "9.39.2",
    "js-yaml": "4.2.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.0"
  },
  "overrides": {
    "flatted": "3.4.2",
    "undici": "6.27.0",
    "vite": "8.0.16"
  }
}
